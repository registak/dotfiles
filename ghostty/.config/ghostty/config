# Font
font-family = "JetBrains Mono"
font-family-bold = "JetBrains Mono"
font-family-italic = "JetBrains Mono"
font-size = 14
font-feature = "calt"
font-feature = "liga"
adjust-cell-height = 25%

# Theme
theme = "catppuccin-mocha"

# Window
window-padding-x = 8
window-padding-y = 4
window-padding-balance = true
window-decoration = true
window-save-state = always

# macOS
macos-option-as-alt = true
macos-titlebar-style = hidden

# Cursor
cursor-style = bar
cursor-style-blink = false

# Clipboard
copy-on-select = clipboard
clipboard-read = ask
clipboard-paste-protection = true

# Scrollback
scrollback-limit = 10000

# Quick Terminal
keybind = global:super+grave_accent=toggle_quick_terminal
quick-terminal-position = top
quick-terminal-animation-duration = 0.15

# Keybinds
keybind = super+t=new_tab
keybind = super+w=close_surface
keybind = super+shift+enter=new_split:right
keybind = super+shift+minus=new_split:down
keybind = super+alt+left=goto_split:left
keybind = super+alt+right=goto_split:right
keybind = super+alt+up=goto_split:top
keybind = super+alt+down=goto_split:bottom

# Misc
confirm-close-surface = false
mouse-hide-while-typing = true
